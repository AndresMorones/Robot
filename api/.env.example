# Robot API — local development env. Copy to .env and fill values.
# DO NOT commit your .env (gitignored at repo root: .env, .env.local, .env.*.local).
# In production these are set via `fly secrets set <KEY>=<value>` (see fly.toml).

# === Inbound auth — protects OUR /v1/* endpoints ===
# Bearer token clients (HR webhooks, Next.js dashboard) present in
# `Authorization: Bearer <token>` OR `x-api-key: <token>` headers. Header-only:
# the legacy `?token=<token>` query-string fallback was removed in ADR-008
# (tokens leak into access logs / referer / browser history).
# The dashboard reads the SAME value from its own .env (server-only import).
# Generate with: openssl rand -hex 32
API_BEARER_TOKEN=<random-32-byte-hex>

# === Loads catalog ===
# Path (relative to api/ working dir) to the loads CSV.
# Spec: "loads will be searched using an API in a file or DB" — this CSV is
# the file backing for the local dev path; production reads from HR Twin.
LOADS_CSV_PATH=../data/loads.csv

# === Outbound — to HR Twin REST API ===
# Base URL for HR's standard API.
# US cluster: https://platform.happyrobot.ai/api/v2
# EU cluster: https://platform.eu.happyrobot.ai/api/v2
HR_BASE_URL=https://platform.happyrobot.ai/api/v2

# HR organization-level API key (sk_live_... format).
# Get from: HR Profile -> Developer Settings -> API Key.
# Used by FastAPI -> HR Twin REST (`/v1/dashboard/*` reads `calls_log` + `bookings`)
# AND referenced by .mcp.json at repo root for the HR MCP server.
# In production: fly secrets set HAPPYROBOT_API_KEY=<value>
# NEVER commit this value.
HAPPYROBOT_API_KEY=sk_live_xxx_replace_me

# HR workflow id for active-call Monitor API proxy (/v1/calls/active).
# Get from HR workflow editor URL: /{org}/workflow/{slug}/editor/{version} —
# the workflow id is on the "Workflows" list / API response. Empty value =
# endpoint returns status="unconfigured" (UI shows "Live status off"); set to
# enable in-flight call detection without an HR-side webhook change.
HR_WORKFLOW_ID=

# === FMCSA QCMobile API key ===
# Free 40-char hex WebKey from https://mobile.fmcsa.dot.gov ("Request Web Key").
# Used by the HR `verify_carrier` webhook URL (baked into the HR workflow);
# also exposed to FastAPI here so deploys can rotate via Fly secret if needed.
FMCSA_WEB_KEY=replace_me_with_your_40_char_fmcsa_webkey

# === Logging ===
# structlog level for application logs (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO

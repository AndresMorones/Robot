# Robot — root-level env for `docker compose up`.
# Copy to .env (gitignored) and fill the values marked REQUIRED.
#
# Per-service env templates with longer prose:
#   - api/.env.example       (full API config detail)
#   - dashboard/.env.example (full dashboard config detail)

# ============================================================================
# REQUIRED — fill these in
# ============================================================================

# Shared Bearer token between API and dashboard. Must be identical.
# Generate: openssl rand -hex 32
API_BEARER_TOKEN=

# HappyRobot org-level API key (sk_live_...).
# Get from: HR Profile -> Developer Settings -> API Key.
# The API uses this server-side to read HR Twin (calls_log + bookings).
# NEVER reaches the browser bundle.
HAPPYROBOT_API_KEY=

# ============================================================================
# OPTIONAL — defaults below match the deployed POC
# ============================================================================

# FMCSA web key — provided as part of the take-home spec. Override only if you
# have your own. The HR `verify_carrier` tool calls FMCSA directly; this var
# is reserved for a future server-side proxy.
# FMCSA_WEB_KEY=cdc33e44d693a3a58451898d4ec9df862c65b954

# HR REST base URL. US: api/v2  ·  EU: eu.platform.happyrobot.ai/api/v2
# HR_BASE_URL=https://platform.happyrobot.ai/api/v2

# HR workflow ID for the active-call Monitor proxy at /v1/calls/active.
# Empty = endpoint reports status="unconfigured" without contacting HR.
# Active workflow: 019db77a-0548-741c-9ac8-d713bea1a51f (Inbound Carrier Sales New)
# HR_WORKFLOW_ID=019db77a-0548-741c-9ac8-d713bea1a51f

# structlog filter level. INFO is fine for local + production.
# LOG_LEVEL=INFO

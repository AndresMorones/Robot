# Robot Dashboard — Next.js 15 App Router server env.
# Copy to .env (or .env.local) and fill values. Both are gitignored.
# In production: `fly secrets set <KEY>=<value>` (see dashboard/fly.toml).

# ============================================================================
# SERVER-ONLY env vars
# ----------------------------------------------------------------------------
# These values NEVER reach the browser bundle. They are read exclusively from
# Next.js Server Components / Route Handlers via `dashboard/src/lib/config.ts`,
# which begins with `import "server-only"` — that import throws at build time
# if any Client Component ("use client") tries to pull `config.ts` into its
# module graph, so leaking the bearer token to the browser is a compile error.
#
# Do NOT prefix any of these with `NEXT_PUBLIC_` — that flag explicitly opts a
# var INTO the client bundle and would defeat the server-only guard.
# ============================================================================

# === Bearer auth — outbound to FastAPI /v1/* ===
# Same value as the API's API_BEARER_TOKEN (see api/.env.example).
# Used by Server Components to fetch /v1/dashboard/{funnel,economics,operational,quality}
# with `Authorization: Bearer <token>` header.
# In production: fly secrets set API_BEARER_TOKEN=<value>
# NEVER commit this value. NEVER expose to the client.
API_BEARER_TOKEN=<random-32-byte-hex>

# === FastAPI base URL ===
# Where the Robot API lives. Local dev: http://localhost:8000
# Production: https://robot-api-andres-morones.fly.dev
# `dashboard/src/lib/config.ts` strips trailing slash + falls back to the
# Fly URL if unset, so this is technically optional for prod deploys.
API_BASE_URL=http://localhost:8000

# === Signed-link auth secret ===
# HMAC-SHA256 secret for the dashboard access middleware (`src/middleware.ts`).
# Generate: openssl rand -hex 32  (or PowerShell: -join ((48..57)+(97..102)|Get-Random -Count 64|%{[char]$_}))
# Used by:
#   1. The dashboard middleware to validate `?t=<exp>.<sig>` signed links
#   2. `scripts/generate_signed_link.py` to mint the link you paste in the email
# Both sides MUST use the same value. Production: fly secrets set LINK_SIGNING_SECRET=...
# Local dev: leave blank to disable middleware enforcement (dev convenience).
LINK_SIGNING_SECRET=
